<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {# ─────────── Title & description ─────────── #}
  {% set pageTitle = title or (site.title + " | " + site.tagline) %}
  {% set pageDescription = description or site.description %}
  <title>{{ pageTitle }}</title>
  <meta name="description" content="{{ pageDescription }}">

  {# ─────────── Canonical URL ─────────── #}
  {% set absoluteUrl = site.url + page.url %}
  <link rel="canonical" href="{{ absoluteUrl }}">

  {# ─────────── Open Graph ─────────── #}
  {% set ogImagePath = ogImage or hero or site.defaultOgImage %}
  {% set ogImageAbsolute = site.url + ogImagePath %}
  {% set resolvedOgType = ogType %}
  {% if not resolvedOgType %}{% if tags and "post" in tags %}{% set resolvedOgType = "article" %}{% else %}{% set resolvedOgType = "website" %}{% endif %}{% endif %}
  <meta property="og:type" content="{{ resolvedOgType }}">
  <meta property="og:site_name" content="{{ site.title }}">
  <meta property="og:locale" content="{{ site.locale }}">
  <meta property="og:title" content="{{ pageTitle }}">
  <meta property="og:description" content="{{ pageDescription }}">
  <meta property="og:url" content="{{ absoluteUrl }}">
  <meta property="og:image" content="{{ ogImageAbsolute }}">
  <meta property="og:image:alt" content="{{ ogImageAlt or pageTitle }}">

  {# ─────────── Twitter Card ─────────── #}
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{{ pageTitle }}">
  <meta name="twitter:description" content="{{ pageDescription }}">
  <meta name="twitter:image" content="{{ ogImageAbsolute }}">

  {# ─────────── Structured data: LocalBusiness (site-wide) ─────────── #}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "@id": "{{ site.url }}/#localbusiness",
    "name": "{{ site.title }}",
    "description": "{{ site.description }}",
    "url": "{{ site.url }}",
    "telephone": "{{ site.phoneE164 }}",
    "email": "{{ site.author.email }}",
    "image": "{{ site.url }}{{ site.defaultOgImage }}",
    "priceRange": "$$",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ site.address.street }}",
      "addressLocality": "{{ site.address.city }}",
      "addressRegion": "{{ site.address.state }}",
      "postalCode": "{{ site.address.zip }}",
      "addressCountry": "{{ site.address.country }}"
    },
    "areaServed": [
      {%- for city in site.areaServed -%}
        { "@type": "City", "name": "{{ city }}" }{% if not loop.last %},{% endif %}
      {%- endfor -%}
    ],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ site.rating.value }}",
      "reviewCount": "{{ site.rating.count }}"
    }
  }
  </script>

  {# ─────────── Article structured data (for blog posts) ─────────── #}
  {% if tags and "post" in tags %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "mainEntityOfPage": {
      "@type": "WebPage",
      "@id": "{{ absoluteUrl }}"
    },
    "headline": {{ title | dump | safe }},
    {% if excerpt %}"description": {{ excerpt | dump | safe }},{% endif %}
    "image": "{{ ogImageAbsolute }}",
    "datePublished": "{{ date | isoDate }}",
    "dateModified": "{{ date | isoDate }}",
    "author": {
      "@type": "Organization",
      "name": "{{ site.title }}",
      "url": "{{ site.url }}"
    },
    "publisher": {
      "@type": "Organization",
      "name": "{{ site.title }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ site.url }}{{ site.defaultOgImage }}"
      }
    }
  }
  </script>
  {% endif %}

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">

  <!-- Tailwind (built) -->
  <link rel="stylesheet" href="/css/tailwind.css">
  <!-- Custom Styles -->
  <link rel="stylesheet" href="/css/styles.css">
</head>

<body class="font-body text-slate-600 bg-white antialiased">

  <!-- Skip to Content -->
  <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:bg-brand-500 focus:text-white focus:px-4 focus:py-2 focus:rounded-lg focus:outline-none">
    Skip to main content
  </a>

  {% include "partials/navbar.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "partials/footer.njk" %}
  {% include "partials/quote-modal.njk" %}

  <!-- Noscript fallback -->
  <noscript>
    <style>
      .reveal-up { opacity: 1; transform: none; }
      #scrub-video-section { display: none; }
    </style>
    <div style="position:fixed;bottom:0;left:0;right:0;z-index:100;background:#1e3a5f;color:white;text-align:center;padding:12px 16px;font-size:14px;">
      For the best experience, please enable JavaScript. You can also call us directly at <a href="tel:+16789999999" style="color:#facc15;text-decoration:underline;">(678) 999-9999</a>.
    </div>
  </noscript>

  <!-- Lucide Icons -->
  <script src="https://unpkg.com/lucide@1.8.0"></script>
  <!-- Main JS -->
  <script src="/js/main.js"></script>
</body>
</html>
