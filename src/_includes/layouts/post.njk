---
layout: layouts/base.njk
---

<article class="pt-28 lg:pt-32">

  <!-- ─── Post Header ─── -->
  <header class="relative bg-gradient-to-b from-brand-50/80 to-white pb-12 lg:pb-16">
    <div class="absolute top-0 right-0 w-96 h-96 bg-brand-100/40 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"></div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-8 lg:pt-12">

      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6">
        <ol class="flex items-center gap-2 text-sm text-slate-500">
          <li><a href="/" class="hover:text-brand-500 transition-colors">Home</a></li>
          <li class="text-slate-300">/</li>
          <li><a href="/blog/" class="hover:text-brand-500 transition-colors">Blog</a></li>
        </ol>
      </nav>

      <!-- Title -->
      <h1 class="font-heading font-extrabold text-3xl sm:text-4xl lg:text-5xl text-brand-900 leading-[1.1] tracking-tight mb-5">
        {{ title }}
      </h1>

      <!-- Meta -->
      <div class="flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-slate-500 mb-8">
        <time datetime="{{ date | isoDate }}" class="flex items-center gap-1.5">
          <i data-lucide="calendar" class="w-4 h-4"></i>
          {{ date | readableDate }}
        </time>
        {% if tags %}
          <span class="hidden sm:block w-1 h-1 bg-slate-300 rounded-full"></span>
          <div class="flex flex-wrap gap-2">
            {% for tag in tags %}
              {% if tag != "post" %}
                <span class="inline-block text-xs font-semibold uppercase tracking-wider text-brand-500 bg-brand-50 px-2.5 py-1 rounded-full">{{ tag }}</span>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      </div>

      {% if excerpt %}
        <p class="text-lg text-slate-600 leading-relaxed">{{ excerpt }}</p>
      {% endif %}
    </div>
  </header>

  <!-- ─── Hero Image (optional) ─── -->
  {% if hero %}
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 -mt-2 mb-12">
      <img src="{{ hero }}" alt="{{ heroAlt or title }}" class="w-full h-auto rounded-2xl shadow-lg shadow-slate-200/50">
    </div>
  {% endif %}

  <!-- ─── Post Body ─── -->
  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-20 lg:pb-28">
    <div class="post-content prose prose-slate max-w-none
                prose-headings:font-heading prose-headings:font-bold prose-headings:text-brand-900 prose-headings:tracking-tight
                prose-h2:text-2xl prose-h2:lg:text-3xl prose-h2:mt-12 prose-h2:mb-4
                prose-h3:text-xl prose-h3:lg:text-2xl prose-h3:mt-8 prose-h3:mb-3
                prose-p:text-base prose-p:lg:text-lg prose-p:text-slate-600 prose-p:leading-relaxed
                prose-a:text-brand-500 prose-a:font-medium prose-a:no-underline hover:prose-a:underline
                prose-strong:text-brand-900 prose-strong:font-semibold
                prose-img:rounded-xl prose-img:shadow-md
                prose-ul:text-slate-600 prose-ol:text-slate-600
                prose-li:my-1
                prose-blockquote:border-l-4 prose-blockquote:border-brand-500 prose-blockquote:bg-brand-50/50 prose-blockquote:py-1 prose-blockquote:px-5 prose-blockquote:not-italic prose-blockquote:rounded-r-lg">
      {{ content | safe }}
    </div>
  </div>

  <!-- ─── Bottom CTA ─── -->
  <section class="bg-gradient-to-b from-white to-brand-50/60 py-16 lg:py-20">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-heading font-bold text-2xl lg:text-3xl text-brand-900 mb-4">Ready to upgrade your windows?</h2>
      <p class="text-slate-500 mb-8">Get a free, no-obligation quote from our Marietta-based team. No high-pressure sales — just honest advice.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/#quote" class="inline-flex items-center justify-center gap-2 bg-brand-500 hover:bg-brand-600 text-white font-semibold px-7 py-4 rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-brand-500/25 active:scale-[0.98]">
          <i data-lucide="message-square" class="w-5 h-5"></i>
          Get Your Free Quote
        </a>
        <a href="{{ site.phoneHref }}" class="inline-flex items-center justify-center gap-2 bg-white border border-slate-200 text-brand-700 font-semibold px-7 py-4 rounded-xl transition-all duration-200 hover:border-brand-300 hover:bg-brand-50 active:scale-[0.98]">
          <i data-lucide="phone" class="w-5 h-5"></i>
          {{ site.phone }}
        </a>
      </div>
      <div class="mt-10">
        <a href="/blog/" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-500 hover:text-brand-600 transition-colors">
          <i data-lucide="arrow-left" class="w-4 h-4"></i>
          Back to all posts
        </a>
      </div>
    </div>
  </section>

</article>
