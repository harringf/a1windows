---
layout: layouts/base.njk
title: Blog | A1 Windows
description: "Tips, guides, and insights on window replacement, energy efficiency, and home improvement from the A1 Windows team in Marietta, GA."
permalink: /blog/index.html
---

<section class="pt-28 lg:pt-32 pb-20 lg:pb-28 bg-gradient-to-b from-brand-50/80 to-white relative overflow-hidden">

  <!-- Decorative background blobs -->
  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-100/40 rounded-full -translate-y-1/2 translate-x-1/3 blur-3xl"></div>
  <div class="absolute bottom-0 left-0 w-72 h-72 bg-brand-100/30 rounded-full translate-y-1/3 -translate-x-1/4 blur-3xl"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center max-w-2xl mx-auto mb-14 lg:mb-18">
      <span class="inline-block font-heading font-semibold text-sm text-brand-500 uppercase tracking-widest mb-3">The A1 Windows Blog</span>
      <h1 class="font-heading font-extrabold text-4xl sm:text-5xl lg:text-6xl text-brand-900 leading-[1.08] tracking-tight mb-5">
        Tips, Guides &amp; <span class="text-brand-500">Window Wisdom</span>
      </h1>
      <p class="text-lg text-slate-500">Practical advice from our Marietta-based team on window replacement, energy efficiency, and getting the most out of your Georgia home.</p>
    </div>

    <!-- Posts -->
    {% set postList = collections.post | reverse %}
    {% if postList.length === 0 %}

      <div class="text-center py-16 px-6 bg-white rounded-2xl border border-slate-200/80">
        <div class="inline-flex items-center justify-center w-14 h-14 bg-brand-50 rounded-2xl mb-4">
          <i data-lucide="pencil-line" class="w-6 h-6 text-brand-500"></i>
        </div>
        <h2 class="font-heading font-semibold text-xl text-brand-900 mb-2">First post coming soon</h2>
        <p class="text-slate-500 max-w-md mx-auto">We're putting the finishing touches on our first article. Check back soon — or get a free quote in the meantime.</p>
        <a href="/#quote" class="inline-flex items-center gap-2 mt-6 bg-brand-500 hover:bg-brand-600 text-white font-semibold px-6 py-3 rounded-xl transition-all duration-200 hover:shadow-lg hover:shadow-brand-500/25">
          Get Your Free Quote
          <i data-lucide="arrow-right" class="w-4 h-4"></i>
        </a>
      </div>

    {% else %}

      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {% for post in postList %}
          <article class="group bg-white rounded-2xl overflow-hidden border border-slate-200/80 transition-all duration-300 hover:shadow-xl hover:shadow-slate-200/50 hover:border-slate-300/80 hover:-translate-y-1 flex flex-col">
            {% if post.data.hero %}
              <a href="{{ post.url }}" class="block aspect-[16/10] overflow-hidden">
                <img src="{{ post.data.hero }}" alt="{{ post.data.heroAlt or post.data.title }}" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy">
              </a>
            {% endif %}
            <div class="p-6 flex flex-col flex-1">
              <time datetime="{{ post.date | isoDate }}" class="text-xs font-semibold uppercase tracking-wider text-brand-500 mb-2">
                {{ post.date | readableDate }}
              </time>
              <h2 class="font-heading font-bold text-lg text-brand-900 mb-2 leading-snug">
                <a href="{{ post.url }}" class="hover:text-brand-500 transition-colors">{{ post.data.title }}</a>
              </h2>
              {% if post.data.excerpt %}
                <p class="text-sm text-slate-500 leading-relaxed mb-4 flex-1">{{ post.data.excerpt }}</p>
              {% endif %}
              <a href="{{ post.url }}" class="inline-flex items-center gap-1.5 text-sm font-semibold text-brand-500 hover:text-brand-600 transition-colors mt-auto">
                Read more
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
              </a>
            </div>
          </article>
        {% endfor %}
      </div>

    {% endif %}

    <!-- RSS hint -->
    <div class="mt-14 text-center">
      <a href="/feed.xml" class="inline-flex items-center gap-2 text-sm text-slate-400 hover:text-brand-500 transition-colors">
        <i data-lucide="rss" class="w-4 h-4"></i>
        Subscribe via RSS
      </a>
    </div>

  </div>
</section>
