{
  "name": "a1windows",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build:css": "tailwindcss -i ./src/css/tailwind.input.css -o ./src/css/tailwind.css --minify",
    "watch:css": "tailwindcss -i ./src/css/tailwind.input.css -o ./src/css/tailwind.css --watch",
    "build:11ty": "eleventy",
    "watch:11ty": "eleventy --serve",
    "build": "npm-run-all build:css build:11ty",
    "dev": "npm-run-all build:css --parallel watch:css watch:11ty"
  },
