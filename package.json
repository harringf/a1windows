  },
  "homepage": "https://github.com/harringf/a1windows#readme",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.5",
    "@11ty/eleventy-plugin-rss": "^3.0.0",
    "@tailwindcss/typography": "^0.5.19",
    "npm-run-all": "^4.1.5",
    "tailwindcss": "^3.4.19"
  }
